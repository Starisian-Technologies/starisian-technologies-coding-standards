# Normalize line endings.
* text=auto eol=lf

# `export-ignore` excludes paths from `git archive` tarballs. Composer
# uses git archive when building dist ZIPs (`composer require` without
# --prefer-source), so these paths stay out of the consumer's vendor/
# tree under that install path. It does NOT affect Composer source
# installs (--prefer-source), which clone the full repo, and it does
# NOT affect npm/pnpm tarballs — those are controlled by the `files`
# array in each package's package.json.

# Generic dev/CI material excluded from the Composer archive.
/.github             export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/docs                export-ignore
/prompts             export-ignore
/QUESTIONS.md        export-ignore
/AGENTS.md           export-ignore
/CODEOWNERS          export-ignore
/THE-STARISIAN-TECHNOLOGIES-CONSTITUTION.md export-ignore

# JS/TS workspace material excluded from the Composer archive so a
# `composer require starisian-technologies/coding-standards` does not
# ship the entire Node toolchain into the consumer's vendor/ tree.
/package.json        export-ignore
/pnpm-workspace.yaml export-ignore
/pnpm-lock.yaml      export-ignore
/packages            export-ignore
